<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="1004.0" prefWidth="1646.0" style="-fx-background-color: radial-gradient(center 50% 50%, radius 80%, #3a7bd5 0%, #001f3f 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.trabajos.TrabajosController">
   <VBox prefHeight="924.0" prefWidth="250.0" style="-fx-background-color: linear-gradient(to bottom right, rgba(26, 54, 104, 0.85), rgba(10, 25, 47, 0.5));">
      <children>
         <ImageView fitHeight="198.0" fitWidth="349.0" pickOnBounds="true" preserveRatio="true">
            <Image url="@assets/imagen_2026-03-14_155500407-removebg-preview.png" />
         </ImageView>
         <Label fx:id="usuarioInfoLabel" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="Sesión iniciada como: Trabajador" />
         <Button onAction="#onVolverClick" prefHeight="55.0" prefWidth="231.0" style="-fx-background-color: linear-gradient(to bottom right, #ef5350, #c62828); -fx-text-fill: white; -fx-border-color: rgba(255, 255, 255, 0.5); -fx-font-weight: bold; -fx-cursor: hand;" text="Cerrar sesion">
            <graphic>
               <ImageView fitHeight="61.0" fitWidth="63.0" pickOnBounds="true" preserveRatio="true">
                  <Image url="@assets/imagen_2026-03-14_202326379-removebg-preview.png" />
               </ImageView>
            </graphic>
            <VBox.margin>
               <Insets left="10.0" />
            </VBox.margin>
         </Button>
      </children>
   </VBox>
   <Label layoutX="606.0" layoutY="114.0" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #ffffff;" text="🔍 Buscar Trabajos" />
   <Label layoutX="606.0" layoutY="181.0" style="-fx-font-size: 14; -fx-text-fill: rgba(255, 255, 255, 0.9);" text="Encuentra la oportunidad laboral que se ajusta a tu perfil" />
   <Label alignment="CENTER" layoutX="316.0" layoutY="14.0" prefHeight="100.0" prefWidth="939.0" style="-fx-text-fill: #ffffff; -fx-font-size: 30; -fx-font-weight: bold;" text="PLATAFORMA DE EMPLEO TEMPORAL">
      <font>
         <Font size="32.0" />
      </font>
   </Label>
   <VBox layoutX="1218.0" layoutY="14.0" prefHeight="873.0" prefWidth="315.0" style="-fx-background-color: linear-gradient(to bottom right, rgba(26, 54, 104, 0.85), rgba(10, 25, 47, 0.5));">
      <children>
         <VBox maxHeight="76.0" maxWidth="150.0" minHeight="76.0" minWidth="150.0" prefHeight="76.0" prefWidth="150.0" />
         <VBox maxWidth="150.0" minWidth="150.0" prefHeight="76.0" prefWidth="150.0" />
         <VBox maxWidth="150.0" minWidth="150.0" prefHeight="76.0" prefWidth="150.0" />
      </children>
   </VBox>
   <TabPane fx:id="tabPane" layoutX="316.0" layoutY="256.0" prefHeight="606.0" prefWidth="802.0">
      <tabs>
         <Tab fx:id="ofertasPublicasTab" closable="false" text="📋 Ofertas Públicas">
            <content>
               <VBox prefHeight="546.0" prefWidth="1118.0" spacing="15">
                  <padding>
                     <Insets bottom="15" left="15" right="15" top="15" />
                  </padding>
                  <children>
                     <HBox fx:id="filtrosContainer" alignment="CENTER_LEFT" spacing="10">
                        <children>
                           <Label style="-fx-text-fill: #ffffff;" text="Filtrar por tipo de trabajo:" />
