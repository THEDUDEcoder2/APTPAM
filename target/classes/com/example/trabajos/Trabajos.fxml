                        </children>
                     </HBox>
                     <TableView fx:id="trabajosTable" style="-fx-background-color: linear-gradient(to bottom right, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.05));" VBox.vgrow="ALWAYS">
                        <columns>
                           <TableColumn fx:id="empresaColumn" prefWidth="200" text="Empresa" />
                           <TableColumn fx:id="vacanteColumn" prefWidth="200" text="Vacante" />
                           <TableColumn fx:id="sueldoColumn" prefWidth="100" text="Sueldo" />
                           <TableColumn fx:id="estadoColumn" prefWidth="120" text="Estado" />
