                     </HBox>
                     <Label fx:id="mensajeLabel" style="-fx-text-fill: #7f8c8d; -fx-font-style: italic; -fx-font-size: 16;" text="No hay trabajos públicos disponibles" visible="false" />
                  </children>
               </VBox>
            </content>
         </Tab>
         <Tab fx:id="ofertasPrivadasTab" closable="false" text="🔷 Ofertas Exclusivas">
            <content>
               <VBox spacing="15">
                  <padding>
                     <Insets bottom="15" left="15" right="15" top="15" />
                  </padding>
                  <children>
                     <Label style="-fx-font-size: 14; -fx-text-fill: #ffffff; -fx-font-weight: bold;" text="Estas ofertas han sido creadas especialmente para ti por empresas interesadas en tu perfil" />
                     <TableView fx:id="ofertasPrivadasTable" style="-fx-background-color: linear-gradient(to bottom right, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.05));" VBox.vgrow="ALWAYS">
                        <columns>
                           <TableColumn fx:id="empresaPrivColumn" prefWidth="200" text="Empresa" />
                           <TableColumn fx:id="puestoPrivColumn" prefWidth="200" text="Puesto" />
                           <TableColumn fx:id="fechaPrivColumn" prefWidth="100" text="Fecha" />
                           <TableColumn fx:id="estadoPrivColumn" prefWidth="120" text="Estado" />
                           <TableColumn fx:id="accionesPrivColumn" prefWidth="150" text="Acciones" />
                        </columns>
                     </TableView>
                     <Label fx:id="mensajePrivadasLabel" style="-fx-text-fill: #7f8c8d; -fx-font-style: italic; -fx-font-size: 16;" text="No tienes ofertas exclusivas en este momento" visible="false" />
