                        <children>
                           <Label fx:id="totalPrivadasLabel" style="-fx-text-fill: #7f8c8d;" text="Ofertas exclusivas para ti: 0" />
                        </children>
                     </HBox>
                  </children>
               </VBox>
            </content>
         </Tab>
      </tabs>
