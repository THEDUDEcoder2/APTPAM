<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="com.example.trabajos" transaction-type="RESOURCE_LOCAL">
        <!-- Provider actualizado para Hibernate 6.x -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Lista todas tus entidades -->
        <class>com.example.trabajos.models.Trabajador</class>
        <class>com.example.trabajos.models.Empresa</class>
        <class>com.example.trabajos.models.Oferta</class>
        <class>com.example.trabajos.models.Postulacion</class>
        <class>com.example.trabajos.models.Genero</class>
        <class>com.example.trabajos.models.Nacionalidad</class>
        <class>com.example.trabajos.models.EstadoCivil</class>
        <class>com.example.trabajos.models.Idioma</class>
        <class>com.example.trabajos.models.SectorActividad</class>
        <class>com.example.trabajos.models.Salario</class>
        <class>com.example.trabajos.models.EstadoContratacion</class>
        <class>com.example.trabajos.models.TrabajadorIdioma</class>
        <class>com.example.trabajos.models.OfertaIdioma</class>
        <class>com.example.trabajos.models.Ciudad</class>
        <class>com.example.trabajos.models.Municipio</class>

        <properties>
            <!-- Configuración de la base de datos -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/Integrador"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="mares10"/>

            <!-- Configuración de Hibernate -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>

            <property name="hibernate.use_sql_comments" value="true"/>

            <property name="hibernate.connection.pool_size" value="10"/>

            <property name="hibernate.enable_lazy_load_no_trans" value="true"/>
        </properties>
    </persistence-unit>
</persistence>