      </VBox>
      <VBox layoutX="1288.0" layoutY="1.0" prefHeight="866.0" prefWidth="280.0" style="-fx-background-color: linear-gradient(to bottom right, rgba(26, 54, 104, 0.85), rgba(10, 25, 47, 0.5));">
         <children>
            <VBox maxHeight="76.0" maxWidth="150.0" minHeight="76.0" minWidth="150.0" prefHeight="76.0" prefWidth="150.0" />
